# ===========================================
# ClawAI Gateway - Environment Configuration
# ===========================================

# Node Environment
NODE_ENV=development

# ===========================================
# Database Configuration
# ===========================================
DATABASE_URL="postgresql://clawai:clawai_secret@localhost:5432/clawai_gateway?schema=public"

# ===========================================
# Redis Configuration
# ===========================================
REDIS_URL="redis://localhost:6379"

# ===========================================
# Authentication
# ===========================================
JWT_SECRET=supersecret123
JWT_EXPIRES_IN="7d"

# ===========================================
# Encryption (for API keys storage)
# ===========================================
ENCRYPTION_KEY=clawai_gateway_super_secret_32

# ===========================================
# API Configuration
# ===========================================
API_PORT=3001
API_HOST=0.0.0.0

# ===========================================
# Web Dashboard Configuration
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:3001

# ===========================================
# AI Provider Keys (Optional - can be added via dashboard)
# ===========================================
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_GEMINI_API_KEY=...

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=debug
LOG_FORMAT=json

# ===========================================
# Request Cache TTL (seconds)
# ===========================================
CACHE_TTL=300
